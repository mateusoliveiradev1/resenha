# Shared database
DATABASE_URL="postgres://USER:PASSWORD@HOST:5432/DBNAME"

# Admin authentication
AUTH_SECRET="replace-with-a-long-random-secret"
# Optional aliases accepted by the current auth stack:
# NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# AUTH_URL="http://localhost:3001"
# NEXTAUTH_URL="http://localhost:3001"

# Public web -> admin redirect
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
# Server-side alias also accepted by the web app:
# ADMIN_APP_URL="http://localhost:3001"

# Public web base URL for canonicals, sitemap and social metadata
# NEXT_PUBLIC_SITE_URL="https://seu-dominio.com"
# SITE_URL="https://seu-dominio.com"

# Important for production on Vercel:
# The current upload flow writes files to local disk (storage/uploads).
# Before production deploy, move uploads to persistent object storage
# such as Vercel Blob, S3-compatible storage, Cloudinary or similar.
# Example if adopting Vercel Blob:
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
